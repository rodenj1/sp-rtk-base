        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "SP-Base · Site Overview",
  "uid": "sp-rtk-base-overview",
  "version": 1,
  "weekStart": ""
}
