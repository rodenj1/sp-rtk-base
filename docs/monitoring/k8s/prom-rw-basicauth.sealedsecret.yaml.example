# ⚠ NOT A REAL SealedSecret.
#
# This file is shape-only.  Real SealedSecrets contain a per-cluster
# encrypted blob that ONLY the sealed-secrets controller in your target
# cluster can decrypt — you cannot author one by hand.
#
# To produce the real one, follow Part B.2 of the runbook
# (docs/monitoring/larson-base-deployment.md):
#
#   htpasswd -nbB larson-base 'THE-SHARED-SECRET' > users.txt
#
#   kubectl create secret generic prom-rw-basicauth \
#     --namespace=monitoring \
#     --from-file=users=users.txt \
#     --dry-run=client -o yaml > prom-rw-basicauth.secret.yaml
#
#   kubeseal --controller-name sealed-secrets-controller \
#            --controller-namespace kube-system \
#            --format yaml \
#            < prom-rw-basicauth.secret.yaml \
#            > prom-rw-basicauth.sealedsecret.yaml
#
#   shred -u prom-rw-basicauth.secret.yaml users.txt
#
# The committed `prom-rw-basicauth.sealedsecret.yaml` is what ArgoCD
# applies; the sealed-secrets controller unseals it to a Secret named
# `prom-rw-basicauth` in the `monitoring` namespace.  Traefik's
# Middleware (prom-rw-middleware.yaml) reads `users` from that Secret.
#
# The shape of the unsealed Secret is:
#
#   apiVersion: v1
#   kind: Secret
#   metadata:
#     name: prom-rw-basicauth
#     namespace: monitoring
#   type: Opaque
#   data:
#     users: <base64 of "larson-base:$2y$05$bcrypt-hash-here">
#
# Rotation:
#   1. Re-run htpasswd with a new password.
#   2. Re-seal.
#   3. Commit.  ArgoCD syncs.  Sealed-secrets controller updates the
#      Secret in place.
#   4. Update /etc/alloy/remote-write.pass on the Pi to match, then
#      `sudo systemctl restart alloy`.
#
# Multi-site:
#   Concatenate htpasswd entries (one per line) before sealing:
#     htpasswd -nbB larson-base 'pw1'  > users.txt
#     htpasswd -nbB crater-base 'pw2' >> users.txt
#   Each remote uses its own username + password pair.
