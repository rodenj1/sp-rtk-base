        "definition": "label_values(sp_rtk_base_relay_running, site)",
        "hide": 0,
        "includeAll": false,
        "label": "Site",
        "multi": false,
        "name": "site",
        "options": [],
        "query": {"query": "label_values(sp_rtk_base_relay_running, site)", "refId": "StandardVariableQuery"},
        "refresh": 1,
        "regex": "",
