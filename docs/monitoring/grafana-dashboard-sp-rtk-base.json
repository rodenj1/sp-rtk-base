{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Operational dashboard for one or more sp-rtk-base relays pushing metrics via Prometheus remote_write.  Pick a site from the $site dropdown.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Green when the most recent sample arrived within the last 2 minutes — the canonical 'is the push pipeline still alive' signal.  Goes red whenever larson-base is offline, the Pi crashed, or the home receiver is broken.",
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"options": {"0": {"color": "red", "text": "STALE"}}, "type": "value"},
            {"options": {"1": {"color": "green", "text": "FRESH"}}, "type": "value"}
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          }
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "id": 1,
      "options": {"colorMode": "background", "graphMode": "none", "textMode": "value_and_name"},
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "(time() - timestamp(sp_rtk_base_relay_uptime_seconds{site=\"$site\"})) < 120",
          "legendFormat": "Pipeline",
          "refId": "A"
        }
      ],
      "title": "Pipeline Freshness",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "1 when the relay engine is running, 0 when stopped.",
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"options": {"0": {"color": "red", "text": "STOPPED"}}, "type": "value"},
            {"options": {"1": {"color": "green", "text": "RUNNING"}}, "type": "value"}
          ]
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "id": 2,
      "options": {"colorMode": "background", "graphMode": "none", "textMode": "value_and_name"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sp_rtk_base_relay_running{site=\"$site\"}",
          "legendFormat": "Relay",
          "refId": "A"
        }
      ],
      "title": "Relay Running",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "How long the relay engine has been continuously running.",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "blue", "value": null}]
          }
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "id": 3,
      "options": {"colorMode": "value", "graphMode": "area"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sp_rtk_base_relay_uptime_seconds{site=\"$site\"}",
          "legendFormat": "Uptime",
          "refId": "A"
        }
      ],
      "title": "Relay Uptime",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Connected destination count out of total registered.",
      "fieldConfig": {"defaults": {"unit": "short"}},
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "id": 4,
      "options": {"colorMode": "value", "graphMode": "none"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sp_rtk_base_active_destinations{site=\"$site\"}",
          "legendFormat": "Active",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sp_rtk_base_total_destinations{site=\"$site\"}",
          "legendFormat": "Total",
          "refId": "B"
        }
      ],
      "title": "Destinations Active / Total",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Rate of RTCM bytes arriving from the GPS input source.  This is the primary 'is data actually flowing' signal — goes to 0 when GPS stops sending even though the connection is still 'up'.",
      "fieldConfig": {"defaults": {"unit": "Bps"}},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "id": 5,
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "values": ["mean", "lastNotNull", "max"]}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "rate(sp_rtk_base_input_bytes_received{site=\"$site\"}[1m])",
          "legendFormat": "RTCM in",
          "refId": "A"
        }
      ],
      "title": "Input rate (RTCM in)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Seconds since the GPS sent its last byte.  Climbs slowly (~1 per second) when the GPS goes silent; should hover under a few seconds during normal operation.",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 10},
              {"color": "red", "value": 30}
            ]
          },
          "custom": {"thresholdsStyle": {"mode": "line"}}
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "id": 6,
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "values": ["lastNotNull", "max"]}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sp_rtk_base_input_seconds_since_last_data{site=\"$site\"}",
          "legendFormat": "Seconds idle",
          "refId": "A"
        }
      ],
      "title": "Seconds Since Last RTCM",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "One line per configured destination — 1 connected, 0 disconnected.",
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          }
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "id": 7,
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "values": ["lastNotNull"]}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sp_rtk_base_dest_connected{site=\"$site\"}",
          "legendFormat": "{{destination}}",
          "refId": "A"
        }
      ],
      "title": "Destinations connected",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Bytes/sec being sent to each destination — same shape as the Input rate, but downstream.  Should track input * (active_destinations) closely.",
      "fieldConfig": {"defaults": {"unit": "Bps"}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "id": 8,
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "values": ["mean", "lastNotNull"]}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "rate(sp_rtk_base_dest_bytes_sent{site=\"$site\"}[1m])",
          "legendFormat": "{{destination}}",
          "refId": "A"
        }
      ],
      "title": "Bytes/s per destination",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Rate of errors per destination.  Should be 0 or flat; spikes indicate an output is misbehaving (NTRIP caster down, SurePath auth expired, TCP server full).",
      "fieldConfig": {"defaults": {"unit": "short"}},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "id": 9,
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "values": ["mean", "lastNotNull", "max"]}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "rate(sp_rtk_base_dest_errors{site=\"$site\"}[5m])",
          "legendFormat": "{{destination}}",
          "refId": "A"
        }
      ],
      "title": "Destination errors /s (5m avg)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Per-destination outbound queue depth — non-zero means the destination is keeping up but momentarily buffered; sustained climb means it's not keeping up.",
      "fieldConfig": {"defaults": {"unit": "short"}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "id": 10,
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "values": ["lastNotNull", "max"]}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sp_rtk_base_dest_queue_depth{site=\"$site\"}",
          "legendFormat": "{{destination}}",
          "refId": "A"
        }
      ],
      "title": "Destination queue depth",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["sp-rtk-base", "rtk", "gnss"],
  "templating": {
    "list": [
